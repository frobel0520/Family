# Copy to .env.local (gitignored) and fill in for local development.
# Neither value is secret — the OAuth Client ID is public by design, and this
# is just the Worker's URL — but they differ between local/dev and production,
# so they're not committed. For the production build, the same names are
# passed in via repository variables in .github/workflows/deploy.yml.

VITE_GOOGLE_CLIENT_ID=
VITE_API_BASE_URL=http://localhost:8787
